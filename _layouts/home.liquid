---
layout: default
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
  /* ── Break out of Bootstrap .container and al-folio max_width ── */
  .container:has(.hp-wrap) {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Inner width guard: content stays readable on ultra-wide screens */
  .hp-inner {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }

  .hp-wrap { font-family: 'DM Sans', var(--font-body, sans-serif); }

  /* ── Hero ── */
  .hp-hero {
    background: #0C2340;
    padding: 5rem 3rem;
    border-bottom: none;
  }
  .hp-hero-layout {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hp-hero-layout { grid-template-columns: 1fr; }
  }
  .hp-eyebrow {
    font-family: 'DM Serif Display', serif; font-size: 35px; font-weight: 400;
    letter-spacing: normal; text-transform: none;
    color: #C99700; margin-bottom: 1.4rem; line-height: 1.25;
  }
  .hp-hero h1 {
    font-family: 'DM Serif Display', serif; font-size: 50px; font-weight: 400; line-height: 1.18;
    color: #fff; margin-bottom: 1.5rem;
  }
  .hp-hero h1 em { color: #C99700; font-style: italic; }
  .hp-hero-desc {
    font-size: 19px; line-height: 1.8; color: rgba(255,255,255,0.7);
    margin-bottom: 2.5rem; max-width: 520px;
  }
  .hp-hero-ctas { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .hp-hero-btn {
    font-size: 15px; font-weight: 600; padding: 14px 28px;
    border-radius: 6px; text-decoration: none; display: inline-block;
    transition: all 0.15s ease;
  }
  .hp-hero-btn.primary { background: #C99700; color: #0C2340; }
  .hp-hero-btn.primary:hover { background: #e0ac0a; }
  .hp-hero-btn.outline { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.32); }
  .hp-hero-btn.outline:hover { border-color: rgba(255,255,255,0.7); }

  /* ── Hero diagram ── */
  .hp-hero-graphic { display: flex; align-items: center; justify-content: center; }
  .hp-hero-graphic svg { width: 100%; max-width: 560px; height: auto; }
  .hp-diagram-node-label {
    font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 600;
  }

  /* ── Mission ── */
  .hp-mission-layout {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .hp-mission-layout { grid-template-columns: 1fr; }
  }
  .hp-mission-quote {
    font-family: 'DM Serif Display', serif; font-size: 27px; font-style: italic; line-height: 1.4;
    color: var(--color-text-primary); margin: 0 0 1.5rem; padding-left: 1.25rem;
    border-left: 3px solid #C99700;
  }
  .hp-mission-text p {
    font-size: 18px; line-height: 1.8; color: var(--color-text-secondary);
    margin-bottom: 1.1rem;
  }
  .hp-metric-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 460px) {
    .hp-metric-grid { grid-template-columns: 1fr; }
  }
  .hp-metric-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-left: 3px solid #C99700;
    border-radius: var(--border-radius-lg, 8px);
    padding: 1.25rem 1.35rem;
  }
  .hp-metric-card.full { grid-column: span 2; }
  @media (max-width: 460px) {
    .hp-metric-card.full { grid-column: span 1; }
  }
  .hp-metric-icon { font-size: 22px; margin-bottom: 0.6rem; display: inline-block; }
  .hp-metric-card h3 {
    font-size: 18px; font-weight: 600; line-height: 1.3;
    color: var(--color-text-primary); margin-bottom: 0.3rem;
  }
  .hp-metric-card p {
    font-size: 15px; line-height: 1.55; color: var(--color-text-tertiary); margin: 0;
  }

  /* ── Generic section ── */
  .hp-section {
    padding: 3.25rem 3rem;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .hp-section-label {
    font-size: 17px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--nd-gold, #C99700); margin-bottom: 0.7rem;
  }
  .hp-section-title {
    font-family: 'DM Serif Display', serif; font-size: 35px;
    color: var(--color-text-primary); margin-bottom: 1.75rem;
  }

  /* ── Research cards ── */
  .hp-research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }
  .hp-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
  }
  .hp-card-thumb {
    width: 100%; height: 160px;
    object-fit: cover;
    object-position: center;
    display: block;
    background: var(--color-background-secondary);
  }
  .hp-card-body { padding: 1.1rem 1.25rem 1.25rem; }
  .hp-card-icon {
    width: 40px; height: 40px; border-radius: var(--border-radius-md, 6px);
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.75rem;
  }
  .hp-card-icon i { font-size: 27px; color: #185FA5; }
  .hp-card h3 { font-size: 21px; font-weight: 500; margin-bottom: 0.4rem; color: var(--color-text-primary); }
  .hp-card p  { font-size: 20px; line-height: 1.65; color: var(--color-text-secondary); }

  /* ── News list ── */
  .hp-news-list { display: flex; flex-direction: column; }
  .hp-news-item {
    display: flex; align-items: flex-start; gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }
  .hp-news-item:last-child { border-bottom: none; }
  .hp-news-date {
    font-size: 18px; color: var(--color-text-tertiary);
    min-width: 82px; padding-top: 2px; flex-shrink: 0;
  }
  .hp-news-body { font-size: 20px; line-height: 1.7; color: var(--color-text-secondary); }
  .hp-news-body strong { color: var(--color-text-primary); font-weight: 500; }
  .hp-news-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-news-more:hover { text-decoration: underline; }

  /* ── Publications ── */
  .hp-pub-venue {
    font-size: 17px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    color: #185FA5; margin-bottom: 0.4rem;
  }
  .hp-pub-title { font-size: 20px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.3rem; line-height: 1.5; }
  .hp-pub-authors { font-size: 19px; color: var(--color-text-secondary); font-style: italic; }
  .hp-pub-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-pub-more:hover { text-decoration: underline; }

  /* ── Visit Us ── */
  .hp-visit {
    background: #0C2340;
    padding: 3.25rem 3rem;
  }
  .hp-visit-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (max-width: 800px) {
    .hp-visit-layout { grid-template-columns: 1fr; }
  }
  .hp-visit-address {
    font-size: 20px; line-height: 1.7;
    color: rgba(255,255,255,0.78);
    margin: 0 0 1.25rem;
  }
  .hp-visit-link {
    display: inline-block;
    font-size: 19px; font-weight: 600;
    color: #C99700; text-decoration: none;
  }
  .hp-visit-link:hover { text-decoration: underline; }
  .hp-visit-photo img {
    width: 100%;
    height: 100%;
    max-height: 320px;
    object-fit: cover;
    border-radius: 14px;
    display: block;
  }

  /* ── Team ── */
  .hp-team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .hp-team-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
    text-align: center;
  }
  .hp-team-card.pi { border-color: #185FA5; }
  .hp-team-photo {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover; object-position: top;
    display: block;
  }
  .hp-team-initials {
    width: 100%; aspect-ratio: 1 / 1;
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; font-weight: 600; color: #185FA5;
  }
  .hp-team-card.open .hp-team-initials { opacity: 0.45; }
  .hp-team-info { padding: 0.9rem 1rem 1rem; }
  .hp-team-card h3 { font-size: 15px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.2rem; }
  .hp-team-card p  { font-size: 13px; color: var(--color-text-secondary); }
  .hp-team-card.open { border-style: dashed; opacity: 0.65; }

  /* ── Join CTA ── */
  .hp-join-box {
    background: #0C2340;
    border-radius: var(--border-radius-lg, 8px);
    padding: 2rem 2.25rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .hp-join-box h3 {
    font-family: 'DM Serif Display', serif; font-size: 26px;
    color: #fff; margin-bottom: 0.5rem;
  }
  .hp-join-box p { font-size: 15px; color: rgba(255,255,255,0.72); max-width: 560px; }
  .hp-join-btn {
    font-size: 14px; font-weight: 600; padding: 12px 24px;
    background: #C99700; color: #0C2340;
    border-radius: var(--border-radius-md, 6px);
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
  }
  .hp-join-btn:hover { background: #b38600; }
</style>

<div class="hp-wrap">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hp-hero">
    <div class="hp-inner">
      <div class="hp-hero-layout">
        <div class="hp-hero-text">
          <h2 class="hp-eyebrow">Advanced Electric Machines &amp; Power<br>Electronics Research Laboratory</h2>
          <p class="hp-hero-desc">
            AMPERE Lab studies electric machines, power electronics, and control as one connected problem to advance electro-mechanical energy conversion systems.<br>Located at the University of Notre Dame, we are strategically positioned in the heart of America's industrial corridor.
          </p>
          <div class="hp-hero-ctas">
            <a class="hp-hero-btn primary" href="{{ '/research/' | relative_url }}">Explore Research</a>
            <a class="hp-hero-btn outline" href="{{ '/publications/' | relative_url }}">Publications</a>
            <a class="hp-hero-btn outline" href="{{ '/join/' | relative_url }}">Join the Lab</a>
          </div>
        </div>
        <div class="hp-hero-graphic">
          <svg viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <radialGradient id="hpCoreGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#FFE9A8"/>
                <stop offset="45%" stop-color="#C99700"/>
                <stop offset="100%" stop-color="#0C2340" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <!-- ══ outer ring of technique nodes, evenly spaced hexagon, dashed spokes to center ══ -->
            <circle cx="240" cy="251" r="178" stroke="rgba(255,255,255,0.10)" stroke-width="1" stroke-dasharray="2 6"/>

            <g stroke="rgba(255,255,255,0.28)" stroke-width="2" stroke-dasharray="3 5">
              <line x1="240" y1="251" x2="240" y2="73"/>
              <line x1="240" y1="251" x2="394" y2="162"/>
              <line x1="240" y1="251" x2="394" y2="340"/>
              <line x1="240" y1="251" x2="240" y2="429"/>
              <line x1="240" y1="251" x2="86"  y2="340"/>
              <line x1="240" y1="251" x2="86"  y2="162"/>
            </g>

            <!-- technique nodes — uniform size (rx=74, ry=29), evenly spaced 60° apart -->
            <!-- Advanced Manufacturing (top) -->
            <ellipse cx="240" cy="73" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="240" y="69"  text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Advanced</text>
            <text x="240" y="84"  text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Manufacturing</text>

            <!-- AI-Assisted Design (upper right) -->
            <ellipse cx="394" cy="162" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="394" y="167" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">AI-Assisted Design</text>

            <!-- Integration (lower right) -->
            <ellipse cx="394" cy="340" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="394" y="345" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Integration</text>

            <!-- Advanced Control (bottom) -->
            <ellipse cx="240" cy="429" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="240" y="434" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Advanced Control</text>

            <!-- Topology Optimization (lower left) -->
            <ellipse cx="86" cy="340" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="86" y="336" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Topology</text>
            <text x="86" y="351" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Optimization</text>

            <!-- Multi-Physics (upper left) -->
            <ellipse cx="86" cy="162" rx="74" ry="29" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="86" y="167" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Multi-Physics</text>

            <!-- ══ central Venn intersection: Electric Machines / Power Electronics / Control ══ -->
            <g opacity="0.9">
              <circle cx="206" cy="222" r="64" stroke="#C99700" stroke-width="1.4"/>
              <circle cx="274" cy="222" r="64" stroke="#185FA5" stroke-width="1.4"/>
              <circle cx="240" cy="280" r="64" stroke="#ffffff" stroke-opacity="0.55" stroke-width="1.4"/>
            </g>

            <!-- glowing core at the triple intersection -->
            <circle cx="240" cy="248" r="34" fill="url(#hpCoreGlow)" opacity="0.95"/>
            <circle cx="240" cy="248" r="9" fill="#FFE9A8"/>

            <!-- domain labels — nudged inward, away from circle edges -->
            <text x="190" y="206" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Electric</text>
            <text x="190" y="221" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Machines</text>

            <text x="290" y="206" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Power</text>
            <text x="290" y="221" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Electronics</text>

            <text x="240" y="318" text-anchor="middle" fill="#ffffff" class="hp-diagram-node-label">Control</text>

            <!-- watermark -->
            <text x="240" y="476" text-anchor="middle" fill="rgba(255,255,255,0.38)" letter-spacing="4" style="font-family:'DM Serif Display', serif; font-size:14px;">AMPERE LAB</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Mission ───────────────────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Our Mission</div>
      <div class="hp-section-title">Building Better Electro-Mechanical Systems</div>
      <p style="font-size:19px; line-height:1.8; color:var(--color-text-secondary); max-width:800px; margin-bottom:2.25rem;">
        We operate at the intersection of electric machines, power electronics, and control — with a passion for integrated, unconventional designs that push the performance envelope.
      </p>

      <div class="hp-mission-layout">
        <div class="hp-mission-text">
          <blockquote class="hp-mission-quote">
            "We create electro-mechanical systems that are more efficient, more affordable, more intelligent, and less dependent on critical materials."
          </blockquote>
          <p>
            AMPERE Lab combines rigorous analytical methods with hands-on hardware development. From winding theory and electromagnetic analysis to 3D-printed prototypes and dynamometer testing, we pursue research that leads to real, deployable technology.
          </p>
          <p>
            We welcome collaboration with industry partners and are actively building a world-class team.
          </p>
        </div>

        <div class="hp-metric-grid">
          <div class="hp-metric-card">
            <i class="ti ti-bolt hp-metric-icon" style="color:#C99700;"></i>
            <h3>Higher Power Density</h3>
            <p>More power in compact, lighter packages</p>
          </div>
          <div class="hp-metric-card">
            <i class="ti ti-flame hp-metric-icon" style="color:#d9622b;"></i>
            <h3>Lower Losses</h3>
            <p>Minimizing losses and thermal requirements</p>
          </div>
          <div class="hp-metric-card">
            <i class="ti ti-tool hp-metric-icon" style="color:#185FA5;"></i>
            <h3>Greater Reliability</h3>
            <p>Minimal down-time and self-diagnosis</p>
          </div>
          <div class="hp-metric-card">
            <i class="ti ti-coin hp-metric-icon" style="color:#C99700;"></i>
            <h3>Affordability</h3>
            <p>High-performance, yet low-cost designs</p>
          </div>
          <div class="hp-metric-card full">
            <i class="ti ti-world hp-metric-icon" style="color:#1f9d6b;"></i>
            <h3>Reduced Critical Material Dependence</h3>
            <p>Low reliance on rare-earth elements and scarce supply chains</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── News ──────────────────────────────────────────── -->
  {% if site.announcements.enabled %}
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Latest News</div>
      <div class="hp-section-title">Lab updates</div>
      <div class="hp-news-list">
        {% assign news_items = site.news | reverse %}
        {% for item in news_items limit: 5 %}
        <div class="hp-news-item">
          <span class="hp-news-date">{{ item.date | date: "%b %Y" }}</span>
          <div class="hp-news-body">
            {% if item.inline %}
              {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
            {% else %}
              <a href="{{ item.url | relative_url }}" style="color:#185FA5;text-decoration:none;font-weight:500;">{{ item.title }}</a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      <a class="hp-news-more" href="{{ '/news/' | relative_url }}">All news →</a>
    </div>
  </section>
  {% endif %}

  <!-- ── Selected Publications ─────────────────────────── -->
  <section class="hp-section" style="border-bottom:none;">
    <div class="hp-inner">
      <div class="hp-section-label">Selected Publications</div>
      <div class="hp-section-title">Recent work</div>
      {% include selected_papers.liquid %}
      <a class="hp-pub-more" href="{{ '/publications/' | relative_url }}">All publications →</a>
    </div>
  </section>

  <!-- ── Visit Us ──────────────────────────────────────── -->
  <section class="hp-visit">
    <div class="hp-inner hp-visit-layout">
      <div class="hp-visit-text">
        <div class="hp-section-label" style="color:#FFE9A8;">Visit Us</div>
        <div class="hp-section-title" style="color:#fff;">AMPERE Lab</div>
        <p class="hp-visit-address">
          Stinson-Remick Hall of Engineering<br>
          University of Notre Dame<br>
          South Bend, IN 46637
        </p>
        <a class="hp-visit-link" href="https://maps.google.com/?q=Stinson-Remick+Hall+of+Engineering,+University+of+Notre+Dame,+South+Bend,+IN+46637" target="_blank" rel="noopener">
          Get directions →
        </a>
      </div>
      <div class="hp-visit-photo">
        <img src="{{ '/assets/img/stinson_remick_hall.jpg' | relative_url }}" alt="Stinson-Remick Hall of Engineering, University of Notre Dame">
      </div>
    </div>
  </section>

</div>
