---
layout: default
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
  /* ── Break out of Bootstrap .container and al-folio max_width ── */
  .container:has(.hp-wrap) {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Inner width guard: content stays readable on ultra-wide screens */
  .hp-inner {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }

  .hp-wrap { font-family: 'DM Sans', var(--font-body, sans-serif); }

  /* ── Hero ── */
  .hp-hero {
    padding: 4rem 3rem 3.5rem;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .hp-hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 768px) {
    .hp-hero-layout { grid-template-columns: 1fr; }
    .hp-hero-image { display: none; }
  }
  .hp-hero-image img {
    width: 100%;
    max-height: 380px;
    object-fit: cover;
    border-radius: var(--border-radius-lg, 8px);
    border: 0.5px solid var(--color-border-tertiary);
  }
  .hp-eyebrow {
    font-size: 17px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--nd-gold, #C99700); margin-bottom: 1.1rem;
  }
  .hp-hero h1 {
    font-family: 'DM Serif Display', serif; font-size: 57px; line-height: 1.1;
    color: var(--color-text-primary); margin-bottom: 1.25rem;
  }
  .hp-hero-desc {
    font-size: 23px; line-height: 1.8; color: var(--color-text-secondary);
    margin-bottom: 2.25rem;
  }
  .hp-pills { display: flex; flex-wrap: wrap; gap: 10px; }
  .hp-pill {
    font-size: 18px; padding: 6px 15px;
    border: 0.5px solid var(--color-border-secondary);
    border-radius: 20px; color: var(--color-text-secondary);
    background: var(--color-background-secondary);
  }

  /* ── Generic section ── */
  .hp-section {
    padding: 3.25rem 3rem;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .hp-section-label {
    font-size: 17px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--nd-gold, #C99700); margin-bottom: 0.7rem;
  }
  .hp-section-title {
    font-family: 'DM Serif Display', serif; font-size: 35px;
    color: var(--color-text-primary); margin-bottom: 1.75rem;
  }

  /* ── Research cards ── */
  .hp-research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }
  .hp-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
  }
  .hp-card-thumb {
    width: 100%; height: 160px;
    object-fit: cover;
    object-position: center;
    display: block;
    background: var(--color-background-secondary);
  }
  .hp-card-body { padding: 1.1rem 1.25rem 1.25rem; }
  .hp-card-icon {
    width: 40px; height: 40px; border-radius: var(--border-radius-md, 6px);
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.75rem;
  }
  .hp-card-icon i { font-size: 27px; color: #185FA5; }
  .hp-card h3 { font-size: 21px; font-weight: 500; margin-bottom: 0.4rem; color: var(--color-text-primary); }
  .hp-card p  { font-size: 20px; line-height: 1.65; color: var(--color-text-secondary); }

  /* ── News list ── */
  .hp-news-list { display: flex; flex-direction: column; }
  .hp-news-item {
    display: flex; align-items: flex-start; gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }
  .hp-news-item:last-child { border-bottom: none; }
  .hp-news-date {
    font-size: 18px; color: var(--color-text-tertiary);
    min-width: 82px; padding-top: 2px; flex-shrink: 0;
  }
  .hp-news-body { font-size: 20px; line-height: 1.7; color: var(--color-text-secondary); }
  .hp-news-body strong { color: var(--color-text-primary); font-weight: 500; }
  .hp-news-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-news-more:hover { text-decoration: underline; }

  /* ── Publications ── */
  .hp-pub-venue {
    font-size: 17px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    color: #185FA5; margin-bottom: 0.4rem;
  }
  .hp-pub-title { font-size: 20px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.3rem; line-height: 1.5; }
  .hp-pub-authors { font-size: 19px; color: var(--color-text-secondary); font-style: italic; }
  .hp-pub-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-pub-more:hover { text-decoration: underline; }

  /* ── Team ── */
  .hp-team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .hp-team-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
    text-align: center;
  }
  .hp-team-card.pi { border-color: #185FA5; }
  .hp-team-photo {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover; object-position: top;
    display: block;
  }
  .hp-team-initials {
    width: 100%; aspect-ratio: 1 / 1;
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; font-weight: 600; color: #185FA5;
  }
  .hp-team-card.open .hp-team-initials { opacity: 0.45; }
  .hp-team-info { padding: 0.9rem 1rem 1rem; }
  .hp-team-card h3 { font-size: 15px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.2rem; }
  .hp-team-card p  { font-size: 13px; color: var(--color-text-secondary); }
  .hp-team-card.open { border-style: dashed; opacity: 0.65; }

  /* ── Join CTA ── */
  .hp-join-box {
    background: #0C2340;
    border-radius: var(--border-radius-lg, 8px);
    padding: 2rem 2.25rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .hp-join-box h3 {
    font-family: 'DM Serif Display', serif; font-size: 26px;
    color: #fff; margin-bottom: 0.5rem;
  }
  .hp-join-box p { font-size: 15px; color: rgba(255,255,255,0.72); max-width: 560px; }
  .hp-join-btn {
    font-size: 14px; font-weight: 600; padding: 12px 24px;
    background: #C99700; color: #0C2340;
    border-radius: var(--border-radius-md, 6px);
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
  }
  .hp-join-btn:hover { background: #b38600; }
</style>

<div class="hp-wrap">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hp-hero">
    <div class="hp-inner">
      <div class="hp-hero-layout">
        <div class="hp-hero-text">
          <div class="hp-eyebrow">Electrical Engineering &middot; University of Notre Dame</div>
          <h1>AMPERE Lab</h1>
          <p class="hp-hero-desc">
            Welcome to the Advanced Electric Machines and Power Electronics Research (AMPERE) Laboratory at the University of Notre Dame.
            We design, analyze, and control high-performance electro-mechanical systems —
            advancing sustainable energy conversion for energy generation, electric vehicles, aerospace, actuators, and industrial systems.

          We operate at the intersection of the traditional areas of electric machines, power electronics, and control, with a soft spot for highly integrated, cool, and "weird" designs that push the performance envelope.
          </p>
        </div>
        <div class="hp-hero-image">
          <img src="{{ '/assets/img/AMProject/AMStator.png' | relative_url }}"
               alt="3D-printed additively manufactured electric machine stator">
        </div>
      </div>
    </div>
  </section>

  <!-- ── Research ──────────────────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Research Focus</div>
      <div class="hp-section-title">What we work on</div>
      <div class="hp-research-grid">

        <div class="hp-card">
          <img class="hp-card-thumb"
               src="{{ '/assets/img/Multi-harmonicProject/MethodSummary.png' | relative_url }}"
               alt="Multi-harmonic winding design method">
          <div class="hp-card-body">
            <h3>Novel Machine Topologies</h3>
            <p>Multi-harmonic and bearingless machines for high power density and rare-earth-free operation.</p>
          </div>
        </div>

        <div class="hp-card">
          <img class="hp-card-thumb"
               src="{{ '/assets/img/HECMProject/HECMSection.png' | relative_url }}"
               alt="Power electronic drive cross-section">
          <div class="hp-card-body">
            <h3>Power Electronic Drives</h3>
            <p>Converter design co-optimized with machine electromagnetics for maximum system efficiency.</p>
          </div>
        </div>

        <div class="hp-card">
          <img class="hp-card-thumb"
               src="{{ '/assets/img/Multi-harmonicProject/DesignExample.png' | relative_url }}"
               alt="Physics-based control winding layout">
          <div class="hp-card-body">
            <h3>Physics-Based Control</h3>
            <p>Model-driven control strategies that exploit machine physics for robust, high-bandwidth performance.</p>
          </div>
        </div>

        <div class="hp-card">
          <img class="hp-card-thumb"
               src="{{ '/assets/img/AMProject/AMStator.png' | relative_url }}"
               alt="Additively manufactured stator">
          <div class="hp-card-body">
            <h3>Additive Manufacturing</h3>
            <p>3D-printed stators and multi-material rotors enabling geometries beyond lamination stacking.</p>
          </div>
        </div>

      </div>
      <p style="margin-top:1.25rem;">
        <a href="{{ '/research/' | relative_url }}" style="font-size:14px;color:#185FA5;text-decoration:none;">See all research areas →</a>
      </p>
    </div>
  </section>

  <!-- ── News ──────────────────────────────────────────── -->
  {% if site.announcements.enabled %}
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Latest News</div>
      <div class="hp-section-title">Lab updates</div>
      <div class="hp-news-list">
        {% assign news_items = site.news | reverse %}
        {% for item in news_items limit: 5 %}
        <div class="hp-news-item">
          <span class="hp-news-date">{{ item.date | date: "%b %Y" }}</span>
          <div class="hp-news-body">
            {% if item.inline %}
              {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
            {% else %}
              <a href="{{ item.url | relative_url }}" style="color:#185FA5;text-decoration:none;font-weight:500;">{{ item.title }}</a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      <a class="hp-news-more" href="{{ '/news/' | relative_url }}">All news →</a>
    </div>
  </section>
  {% endif %}

  <!-- ── Selected Publications ─────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Selected Publications</div>
      <div class="hp-section-title">Recent work</div>
      {% include selected_papers.liquid %}
      <a class="hp-pub-more" href="{{ '/publications/' | relative_url }}">All publications →</a>
    </div>
  </section>

  <!-- ── People ────────────────────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">People</div>
      <div class="hp-section-title">The team</div>
      <div class="hp-team-grid">

        <div class="hp-team-card pi">
          <img class="hp-team-photo"
               src="{{ '/assets/img/prof_pic.png' | relative_url }}"
               alt="Prof. Nishanth Gadiyar">
          <div class="hp-team-info">
            <h3>Nishanth Gadiyar</h3>
            <p>Principal Investigator</p>
          </div>
        </div>

        <div class="hp-team-card open">
          <div class="hp-team-initials"><i class="ti ti-user-plus" style="font-size:32px;"></i></div>
          <div class="hp-team-info">
            <h3>PhD Student</h3>
            <p>Recruiting Fall 2026</p>
          </div>
        </div>

        <div class="hp-team-card open">
          <div class="hp-team-initials"><i class="ti ti-user-plus" style="font-size:32px;"></i></div>
          <div class="hp-team-info">
            <h3>PhD Student</h3>
            <p>Recruiting Fall 2026</p>
          </div>
        </div>

      </div>
      <p style="margin-top:1.25rem;">
        <a href="{{ '/people/' | relative_url }}" style="font-size:14px;color:#185FA5;text-decoration:none;">Meet the full team →</a>
      </p>
    </div>
  </section>

  <!-- ── Join CTA ──────────────────────────────────────── -->
  <section class="hp-section" style="border-bottom:none;">
    <div class="hp-inner">
      <div class="hp-join-box">
        <div>
          <h3>Join our lab</h3>
          <p>We are always on the lookout for motivated undergrads with a passion to build things, graduate students and postdocs with backgrounds in electric machines, power electronics, or controls.</p>
        </div>
        <a class="hp-join-btn" href="{{ '/join/' | relative_url }}">Get in touch ↗</a>
      </div>
    </div>
  </section>

</div>
