---
layout: default
---

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

<style>
  /* ── Break out of Bootstrap .container and al-folio max_width ── */
  .container:has(.hp-wrap) {
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
  }

  /* Inner width guard: content stays readable on ultra-wide screens */
  .hp-inner {
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }

  .hp-wrap { font-family: 'DM Sans', var(--font-body, sans-serif); }

  /* ── Hero ── */
  .hp-hero {
    background: #0C2340;
    padding: 5rem 3rem;
    border-bottom: none;
  }
  .hp-hero-layout {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hp-hero-layout { grid-template-columns: 1fr; }
  }
  .hp-eyebrow {
    font-size: 14px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase;
    color: #C99700; margin-bottom: 1.4rem; line-height: 1.6;
  }
  .hp-hero h1 {
    font-family: 'DM Serif Display', serif; font-size: 50px; font-weight: 400; line-height: 1.18;
    color: #fff; margin-bottom: 1.5rem;
  }
  .hp-hero h1 em { color: #C99700; font-style: italic; }
  .hp-hero-desc {
    font-size: 19px; line-height: 1.8; color: rgba(255,255,255,0.7);
    margin-bottom: 2.5rem; max-width: 520px;
  }
  .hp-hero-ctas { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .hp-hero-btn {
    font-size: 15px; font-weight: 600; padding: 14px 28px;
    border-radius: 6px; text-decoration: none; display: inline-block;
    transition: all 0.15s ease;
  }
  .hp-hero-btn.primary { background: #C99700; color: #0C2340; }
  .hp-hero-btn.primary:hover { background: #e0ac0a; }
  .hp-hero-btn.outline { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.32); }
  .hp-hero-btn.outline:hover { border-color: rgba(255,255,255,0.7); }

  /* ── Hero diagram ── */
  .hp-hero-graphic { display: flex; align-items: center; justify-content: center; }
  .hp-hero-graphic svg { width: 100%; max-width: 460px; height: auto; }
  .hp-diagram-node-label {
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 600;
  }

  /* ── Generic section ── */
  .hp-section {
    padding: 3.25rem 3rem;
    border-bottom: 1px solid var(--color-border-tertiary);
  }
  .hp-section-label {
    font-size: 17px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
    color: var(--nd-gold, #C99700); margin-bottom: 0.7rem;
  }
  .hp-section-title {
    font-family: 'DM Serif Display', serif; font-size: 35px;
    color: var(--color-text-primary); margin-bottom: 1.75rem;
  }

  /* ── Research cards ── */
  .hp-research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.1rem;
  }
  .hp-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
  }
  .hp-card-thumb {
    width: 100%; height: 160px;
    object-fit: cover;
    object-position: center;
    display: block;
    background: var(--color-background-secondary);
  }
  .hp-card-body { padding: 1.1rem 1.25rem 1.25rem; }
  .hp-card-icon {
    width: 40px; height: 40px; border-radius: var(--border-radius-md, 6px);
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.75rem;
  }
  .hp-card-icon i { font-size: 27px; color: #185FA5; }
  .hp-card h3 { font-size: 21px; font-weight: 500; margin-bottom: 0.4rem; color: var(--color-text-primary); }
  .hp-card p  { font-size: 20px; line-height: 1.65; color: var(--color-text-secondary); }

  /* ── News list ── */
  .hp-news-list { display: flex; flex-direction: column; }
  .hp-news-item {
    display: flex; align-items: flex-start; gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 0.5px solid var(--color-border-tertiary);
  }
  .hp-news-item:last-child { border-bottom: none; }
  .hp-news-date {
    font-size: 18px; color: var(--color-text-tertiary);
    min-width: 82px; padding-top: 2px; flex-shrink: 0;
  }
  .hp-news-body { font-size: 20px; line-height: 1.7; color: var(--color-text-secondary); }
  .hp-news-body strong { color: var(--color-text-primary); font-weight: 500; }
  .hp-news-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-news-more:hover { text-decoration: underline; }

  /* ── Publications ── */
  .hp-pub-venue {
    font-size: 17px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase;
    color: #185FA5; margin-bottom: 0.4rem;
  }
  .hp-pub-title { font-size: 20px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.3rem; line-height: 1.5; }
  .hp-pub-authors { font-size: 19px; color: var(--color-text-secondary); font-style: italic; }
  .hp-pub-more {
    display: inline-block; margin-top: 1.1rem; font-size: 19px;
    color: #185FA5; text-decoration: none;
  }
  .hp-pub-more:hover { text-decoration: underline; }

  /* ── Team ── */
  .hp-team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }
  .hp-team-card {
    background: var(--color-background-primary);
    border: 0.5px solid var(--color-border-tertiary);
    border-radius: var(--border-radius-lg, 8px);
    overflow: hidden;
    text-align: center;
  }
  .hp-team-card.pi { border-color: #185FA5; }
  .hp-team-photo {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover; object-position: top;
    display: block;
  }
  .hp-team-initials {
    width: 100%; aspect-ratio: 1 / 1;
    background: var(--color-background-secondary);
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; font-weight: 600; color: #185FA5;
  }
  .hp-team-card.open .hp-team-initials { opacity: 0.45; }
  .hp-team-info { padding: 0.9rem 1rem 1rem; }
  .hp-team-card h3 { font-size: 15px; font-weight: 500; color: var(--color-text-primary); margin-bottom: 0.2rem; }
  .hp-team-card p  { font-size: 13px; color: var(--color-text-secondary); }
  .hp-team-card.open { border-style: dashed; opacity: 0.65; }

  /* ── Join CTA ── */
  .hp-join-box {
    background: #0C2340;
    border-radius: var(--border-radius-lg, 8px);
    padding: 2rem 2.25rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .hp-join-box h3 {
    font-family: 'DM Serif Display', serif; font-size: 26px;
    color: #fff; margin-bottom: 0.5rem;
  }
  .hp-join-box p { font-size: 15px; color: rgba(255,255,255,0.72); max-width: 560px; }
  .hp-join-btn {
    font-size: 14px; font-weight: 600; padding: 12px 24px;
    background: #C99700; color: #0C2340;
    border-radius: var(--border-radius-md, 6px);
    text-decoration: none; white-space: nowrap; flex-shrink: 0;
  }
  .hp-join-btn:hover { background: #b38600; }
</style>

<div class="hp-wrap">

  <!-- ── Hero ──────────────────────────────────────────── -->
  <section class="hp-hero">
    <div class="hp-inner">
      <div class="hp-hero-layout">
        <div class="hp-hero-text">
          <div class="hp-eyebrow">Advanced Electric Machines &amp; Power<br>Electronics Research</div>
          <h1>Inventing the Next Generation of <em>Electro-Mechanical Systems</em></h1>
          <p class="hp-hero-desc">
            From artificial hearts to aerospace systems, AMPERE Lab develops high-performance electro-mechanical technologies through machine innovation, AI-assisted design, advanced manufacturing, and system integration.
          </p>
          <div class="hp-hero-ctas">
            <a class="hp-hero-btn primary" href="{{ '/research/' | relative_url }}">Explore Research</a>
            <a class="hp-hero-btn outline" href="{{ '/publications/' | relative_url }}">Publications</a>
            <a class="hp-hero-btn outline" href="{{ '/join/' | relative_url }}">Join the Lab</a>
          </div>
        </div>
        <div class="hp-hero-graphic">
          <svg viewBox="0 0 480 480" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- outer dashed orbit -->
            <circle cx="240" cy="240" r="190" stroke="rgba(255,255,255,0.14)" stroke-width="1" stroke-dasharray="3 6"/>
            <!-- middle dashed orbit -->
            <circle cx="240" cy="240" r="132" stroke="rgba(201,151,0,0.35)" stroke-width="1" stroke-dasharray="2 5"/>
            <!-- radiating ticks -->
            <g stroke="rgba(255,255,255,0.18)" stroke-width="1.5">
              <line x1="240" y1="58"  x2="240" y2="74"/>
              <line x1="240" y1="406" x2="240" y2="422"/>
              <line x1="58"  y1="240" x2="74"  y2="240"/>
              <line x1="406" y1="240" x2="422" y2="240"/>
              <line x1="104" y1="104" x2="116" y2="116"/>
              <line x1="364" y1="364" x2="376" y2="376"/>
              <line x1="376" y1="104" x2="364" y2="116"/>
              <line x1="116" y1="364" x2="104" y2="376"/>
            </g>
            <!-- connecting lines from center to nodes -->
            <line x1="240" y1="240" x2="240" y2="112" stroke="#C99700" stroke-width="1" stroke-dasharray="2 4" opacity="0.6"/>
            <line x1="240" y1="240" x2="240" y2="368" stroke="#C99700" stroke-width="1" stroke-dasharray="2 4" opacity="0.6"/>
            <line x1="240" y1="240" x2="118" y2="240" stroke="#185FA5" stroke-width="1" opacity="0.55"/>
            <line x1="240" y1="240" x2="362" y2="240" stroke="#185FA5" stroke-width="1" opacity="0.55"/>

            <!-- center glow -->
            <defs>
              <radialGradient id="hpCoreGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#FFE9A8"/>
                <stop offset="45%" stop-color="#C99700"/>
                <stop offset="100%" stop-color="#0C2340" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <circle cx="240" cy="240" r="46" fill="url(#hpCoreGlow)" opacity="0.9"/>
            <circle cx="240" cy="240" r="13" fill="#FFE9A8"/>
            <circle cx="240" cy="240" r="13" stroke="#C99700" stroke-width="1.5"/>

            <!-- top node: AI-Assisted Optimization -->
            <ellipse cx="240" cy="92" rx="78" ry="20" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="240" y="89" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">AI-Assisted</text>
            <text x="240" y="101" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Optimization</text>

            <!-- bottom node: Advanced Manufacturing -->
            <ellipse cx="240" cy="388" rx="84" ry="20" fill="rgba(255,255,255,0.04)" stroke="#C99700" stroke-width="1"/>
            <text x="240" y="385" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Advanced</text>
            <text x="240" y="397" text-anchor="middle" fill="#FFE9A8" class="hp-diagram-node-label">Manufacturing</text>

            <!-- left node: Power Electronics -->
            <rect x="30" y="216" width="100" height="48" rx="6" fill="rgba(255,255,255,0.04)" stroke="#185FA5" stroke-width="1"/>
            <text x="80" y="237" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Power</text>
            <text x="80" y="250" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Electronics</text>

            <!-- right node: Mechanical Load -->
            <rect x="350" y="216" width="100" height="48" rx="6" fill="rgba(255,255,255,0.04)" stroke="#185FA5" stroke-width="1"/>
            <text x="400" y="237" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Mechanical</text>
            <text x="400" y="250" text-anchor="middle" fill="#bfe0ff" class="hp-diagram-node-label">Load</text>

            <!-- watermark -->
            <text x="240" y="450" text-anchor="middle" fill="rgba(255,255,255,0.15)" letter-spacing="4" style="font-family:'DM Serif Display', serif; font-size:15px;">AMPERE LAB</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- ── News ──────────────────────────────────────────── -->
  {% if site.announcements.enabled %}
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Latest News</div>
      <div class="hp-section-title">Lab updates</div>
      <div class="hp-news-list">
        {% assign news_items = site.news | reverse %}
        {% for item in news_items limit: 5 %}
        <div class="hp-news-item">
          <span class="hp-news-date">{{ item.date | date: "%b %Y" }}</span>
          <div class="hp-news-body">
            {% if item.inline %}
              {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
            {% else %}
              <a href="{{ item.url | relative_url }}" style="color:#185FA5;text-decoration:none;font-weight:500;">{{ item.title }}</a>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      </div>
      <a class="hp-news-more" href="{{ '/news/' | relative_url }}">All news →</a>
    </div>
  </section>
  {% endif %}

  <!-- ── Selected Publications ─────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">Selected Publications</div>
      <div class="hp-section-title">Recent work</div>
      {% include selected_papers.liquid %}
      <a class="hp-pub-more" href="{{ '/publications/' | relative_url }}">All publications →</a>
    </div>
  </section>

  <!-- ── People ────────────────────────────────────────── -->
  <section class="hp-section">
    <div class="hp-inner">
      <div class="hp-section-label">People</div>
      <div class="hp-section-title">The team</div>
      <div class="hp-team-grid">

        <div class="hp-team-card pi">
          <img class="hp-team-photo"
               src="{{ '/assets/img/prof_pic.png' | relative_url }}"
               alt="Prof. Nishanth Gadiyar">
          <div class="hp-team-info">
            <h3>Nishanth Gadiyar</h3>
            <p>Principal Investigator</p>
          </div>
        </div>

        <div class="hp-team-card open">
          <div class="hp-team-initials"><i class="ti ti-user-plus" style="font-size:32px;"></i></div>
          <div class="hp-team-info">
            <h3>PhD Student</h3>
            <p>Recruiting Fall 2026</p>
          </div>
        </div>

        <div class="hp-team-card open">
          <div class="hp-team-initials"><i class="ti ti-user-plus" style="font-size:32px;"></i></div>
          <div class="hp-team-info">
            <h3>PhD Student</h3>
            <p>Recruiting Fall 2026</p>
          </div>
        </div>

      </div>
      <p style="margin-top:1.25rem;">
        <a href="{{ '/people/' | relative_url }}" style="font-size:14px;color:#185FA5;text-decoration:none;">Meet the full team →</a>
      </p>
    </div>
  </section>

  <!-- ── Join CTA ──────────────────────────────────────── -->
  <section class="hp-section" style="border-bottom:none;">
    <div class="hp-inner">
      <div class="hp-join-box">
        <div>
          <h3>Join our lab</h3>
          <p>We are always on the lookout for motivated undergrads with a passion to build things, graduate students and postdocs with backgrounds in electric machines, power electronics, or controls.</p>
        </div>
        <a class="hp-join-btn" href="{{ '/join/' | relative_url }}">Get in touch ↗</a>
      </div>
    </div>
  </section>

</div>
